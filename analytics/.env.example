# ── Supabase Postgres connection ──────────────────────────────────────────────
# Grafana connects directly to your database to read the analytics tables.
#
# Grab the exact values from the Supabase dashboard:
#   Project → Connect → "Session pooler"  (IPv4-friendly; works from local Docker)
#
# The host region prefix may be aws-0 or aws-1 — copy whatever the dashboard shows.
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.hbiyyreqmliesghdclpg
SUPABASE_DB_PASSWORD=your-database-password

# Alternative — direct connection (IPv6-only on the free plan, often fails from
# a local Docker bridge). Use the pooler above unless you have IPv4 add-on:
#   SUPABASE_DB_HOST=db.hbiyyreqmliesghdclpg.supabase.co
#   SUPABASE_DB_PORT=5432
#   SUPABASE_DB_USER=postgres

# ── Grafana login ─────────────────────────────────────────────────────────────
# Defaults to admin/admin if you leave these out.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
