{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["analytics"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Page Visits",
  "uid": "page-visits",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Page views",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value",
        "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT count(*) AS value FROM page_views WHERE $__timeFilter(created_at)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique visitors",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value",
        "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT count(DISTINCT session_token) AS value FROM page_views WHERE $__timeFilter(created_at)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "New sessions",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value",
        "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT count(*) AS value FROM sessions WHERE $__timeFilter(created_at)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Countries",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value",
        "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT count(DISTINCT country) AS value FROM sessions WHERE $__timeFilter(created_at) AND country IS NOT NULL"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Page views over time",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1,
            "axisPlacement": "auto", "showPoints": "never", "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A", "format": "time_series", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT $__timeGroupAlias(created_at, $__interval), count(*) AS \"page views\" FROM page_views WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "B", "format": "time_series", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT $__timeGroupAlias(created_at, $__interval), count(*) AS \"new sessions\" FROM sessions WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top pages",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT page, count(*) AS views FROM page_views WHERE $__timeFilter(created_at) GROUP BY page ORDER BY views DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top referrers",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT coalesce(nullif(referrer, ''), '(direct)') AS referrer, count(*) AS views FROM page_views WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY views DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top countries",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT s.country, count(*) AS views FROM page_views pv JOIN sessions s USING (session_token) WHERE $__timeFilter(pv.created_at) AND s.country IS NOT NULL GROUP BY s.country ORDER BY views DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 9,
      "type": "geomap",
      "title": "Visitor map",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "view": { "id": "zero", "lat": 0, "lon": 0, "zoom": 1 },
        "controls": { "showZoom": true, "mouseWheelZoom": true, "showAttribution": true, "showScale": false, "showDebug": false },
        "basemap": { "type": "default", "name": "Basemap" },
        "layers": [
          {
            "type": "markers",
            "name": "Visits",
            "location": { "mode": "auto" },
            "config": {
              "style": {
                "size": { "field": "views", "fixed": 5, "min": 4, "max": 22 },
                "color": { "fixed": "dark-orange" },
                "opacity": 0.6,
                "symbol": { "fixed": "img/icons/marker/circle.svg" }
              },
              "showLegend": false
            }
          }
        ]
      },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT s.latitude, s.longitude, max(s.city) AS city, count(*) AS views FROM page_views pv JOIN sessions s USING (session_token) WHERE $__timeFilter(pv.created_at) AND s.latitude IS NOT NULL AND s.longitude IS NOT NULL GROUP BY s.latitude, s.longitude"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top cities",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT s.city, s.country, count(*) AS views FROM page_views pv JOIN sessions s USING (session_token) WHERE $__timeFilter(pv.created_at) AND s.city IS NOT NULL GROUP BY s.city, s.country ORDER BY views DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Recent page views",
      "datasource": { "type": "postgres", "uid": "supabase" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "options": { "showHeader": true, "footer": { "show": false } },
      "targets": [
        {
          "refId": "A", "format": "table", "rawQuery": true,
          "datasource": { "type": "postgres", "uid": "supabase" },
          "rawSql": "SELECT pv.created_at AS \"time\", pv.page, coalesce(s.city, '') AS city, coalesce(s.country, '') AS country, coalesce(nullif(pv.referrer, ''), '(direct)') AS referrer FROM page_views pv LEFT JOIN sessions s USING (session_token) WHERE $__timeFilter(pv.created_at) ORDER BY pv.created_at DESC LIMIT 100"
        }
      ]
    }
  ]
}
